# Dependencies
node_modules/
**/node_modules/

# Build output
web/dist/
**/dist/

# Python (optional AI sandbox)
__pycache__/
*.pyc
.venv/
venv/
server/.venv/

# Local env / secrets — never commit
.env
.env.*
!.env.example

# Netlify CLI local state (never commit; the root netlify.toml IS committed)
.netlify/
**/.netlify/

# Editor / OS
.DS_Store
.vscode/
.idea/
*.log

# Agent/browser session artifacts (Playwright MCP traces, verification screenshots)
.playwright-mcp/
/*.png
.claude/worktrees/

# node_modules symlinks too — the dir patterns above match only real directories,
# which is how a worktree convenience symlink once got committed
**/node_modules
